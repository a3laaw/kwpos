// Prisma schema for the Small Business ERP
// (Sales, Inventory, Purchasing)

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  role         String   @default("SALES") // ADMIN | SALES | WAREHOUSE
  // POS Express Mode preference. Default true for SALES (fast cashier),
  // false for ADMIN (full-featured view). Toggled via the POS toolbar.
  posExpressMode Boolean @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  sales Sale[]
  shifts Shift[]
  spotChecks SpotCheck[]
  suspendedSales SuspendedSale[]
  exchanges ExchangeSale[]
  promotions Promotion[]
  priceChanges PriceChange[]
  purchaseInvoices PurchaseInvoice[]
  supplierPayments SupplierPayment[]
  purchaseReturns PurchaseReturn[]
  stockTakeCreated StockTake[] @relation("StockTakeCreator")
  stockTakeApproved StockTake[] @relation("StockTakeApprover")
  transfersCreated StockTransfer[] @relation("TransferCreator")
  transfersReceived StockTransfer[] @relation("TransferReceiver")
}

model Category {
  id             String    @id @default(cuid())
  name           String    @unique
  code           String?   @unique // short code for display (e.g. "03")
  barcodePrefix  Int?      // explicit barcode prefix digit (1-9). If null, uses order index.
  imageUrl       String?
  createdAt      DateTime  @default(now())
  products       Product[]
}

// Unit of measure (kilo, gram, piece, box...)
model Unit {
  id        String    @id @default(cuid())
  name      String    @unique
  createdAt DateTime  @default(now())
  products  Product[]
}

model Supplier {
  id        String           @id @default(cuid())
  name      String
  contact   String?
  phone     String?
  email     String?
  address   String?
  createdAt DateTime         @default(now())
  products  Product[]        @relation("ProductSupplier")
  defaultForProducts Product[] @relation("DefaultProductSupplier")
  orders    PurchaseOrder[]
  purchaseInvoices PurchaseInvoice[]
  payments  SupplierPayment[]
  purchaseReturns PurchaseReturn[]
}

// ─── MODULE 9: Supplier Payments (سداد الموردين) ────────────────────
// Records payments made to suppliers against their outstanding balance
// (POSTED purchase invoices − payments). Each payment generates a balanced
// journal entry: debit 2010 (Accounts Payable) / credit 1010 (Cash) or
// 1020 (Bank).
model SupplierPayment {
  id             String   @id @default(cuid())
  paymentNo      String   @unique
  supplierId     String
  amount         Float
  paymentDate    DateTime @default(now())
  paymentMethod  String   @default("CASH") // CASH | BANK | CHECK
  referenceNo    String?
  note           String?
  journalEntryId String?
  createdById    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  supplier      Supplier       @relation(fields: [supplierId], references: [id])
  journalEntry  JournalEntry?  @relation(fields: [journalEntryId], references: [id], onDelete: SetNull)
  createdBy     User?          @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@index([supplierId])
  @@index([paymentDate])
}

model Product {
  id              String           @id @default(cuid())
  name            String
  barcode         String?
  categoryId      String?
  quantity        Int              @default(0) // total across all warehouses (derived)
  reorderLevel    Int              @default(5)
  optimalOrderQty Int              @default(0) // optimal reorder quantity (0 = not set)
  costPrice       Float            @default(0)
  salePrice       Float            @default(0) // retail price (default tier)
  wholesalePrice  Float            @default(0) // wholesale tier (0 = same as retail)
  corporatePrice  Float            @default(0) // corporate/contract tier (0 = same as retail)
  unit            String           @default("قطعة")
  unitId          String?
  imageUrl        String? // product image (local path or remote URL)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  category     Category?        @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  supplier     Supplier?        @relation("ProductSupplier", fields: [supplierId], references: [id], onDelete: SetNull)
  supplierId   String? // current supplier (editable)
  defaultSupplierId String? // preferred supplier for auto-PO
  defaultSupplier Supplier? @relation("DefaultProductSupplier", fields: [defaultSupplierId], references: [id], onDelete: SetNull)
  unitRef      Unit?            @relation(fields: [unitId], references: [id], onDelete: SetNull)
  stockItems   StockItem[]
  saleItems    SaleItem[]
  poItems      PurchaseOrderItem[]
  spotChecks   SpotCheck[]
  exchangeLines ExchangeLine[]
  promotions   Promotion[]
  priceChanges PriceChange[]
  purchaseInvoiceItems PurchaseInvoiceItem[]
  purchaseReturnItems PurchaseReturnItem[]
  stockTakeItems StockTakeItem[]
  stockTransferItems StockTransferItem[]
  bundleItems BundleItem[]
  compositionIngredients CompositionIngredient[]
  producedCompositions Composition[] @relation("CompositionOutput")

  @@index([categoryId])
  @@index([supplierId])
  @@index([barcode])
  @@index([name])
}

// Multiple warehouses
model Warehouse {
  id        String     @id @default(cuid())
  name      String
  code      String?    // short code e.g. "WH-01"
  location  String?
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())
  stockItems StockItem[]
  purchaseOrders PurchaseOrder[] @relation("POWarehouse")
  purchaseInvoices PurchaseInvoice[]
  stockTakes StockTake[]
  outgoingTransfers StockTransfer[] @relation("FromWarehouse")
  incomingTransfers StockTransfer[] @relation("ToWarehouse")
}

// Per-warehouse stock levels (a product can exist in many warehouses)
model StockItem {
  id          String   @id @default(cuid())
  productId   String
  warehouseId String
  quantity    Int      @default(0)

  product     Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouse   Warehouse  @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  @@unique([productId, warehouseId])
  @@index([warehouseId])
}

model PurchaseOrder {
  id          String               @id @default(cuid())
  supplierId  String
  warehouseId String? // destination warehouse for received stock
  // PENDING_APPROVAL = auto-draft awaiting manager approval
  // APPROVED = manager approved → ready to send to supplier
  // PENDING = manually created, awaiting receipt (legacy/default)
  // RECEIVED = goods received, stock updated, cost prices recalculated
  // CANCELLED = cancelled
  // REJECTED = manager rejected the auto-draft
  status      String               @default("PENDING") // PENDING_APPROVAL | APPROVED | PENDING | RECEIVED | CANCELLED | REJECTED
  rejectionReason String?
  total       Float                @default(0)
  // VAT rate (%) for this PO. Default 0. When the PO is received, the
  // receive route computes receivedTaxAmount = subtotal × taxRate / 100
  // and stores it on the PO so the VAT report can include it.
  taxRate     Float                @default(0)
  // Landed cost: extra charges allocated across items
  customsAmount  Float             @default(0) // جمارك
  shippingAmount Float             @default(0) // شحن
  otherCharges   Float             @default(0) // رسوم أخرى
  landedCostApplied Boolean        @default(false) // whether cost prices were updated on receipt
  // VAT/tax amount computed at receive time (subtotal × taxRate). Stored so
  // the VAT report can include PO receives even when no PurchaseInvoice is
  // posted. Prevents double-counting: if a PurchaseInvoice is later posted
  // for this PO, its taxAmount is netted against receivedTaxAmount.
  receivedTaxAmount Float         @default(0)
  note        String?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  supplier    Supplier             @relation(fields: [supplierId], references: [id])
  warehouse   Warehouse?           @relation("POWarehouse", fields: [warehouseId], references: [id], onDelete: SetNull)
  items       PurchaseOrderItem[]
  purchaseInvoices PurchaseInvoice[]
  purchaseReturns PurchaseReturn[]

  @@index([supplierId])
  @@index([status])
  @@index([createdAt])
}

model PurchaseOrderItem {
  id              String        @id @default(cuid())
  purchaseOrderId String
  productId       String
  quantity        Int
  unitCost        Float
  subtotal        Float
  // Optional manager-suggested retail sale price for this product. When set
  // (> 0) and different from the product's current `salePrice`, the receive
  // flow writes a PriceChange audit row + updates the product's salePrice
  // via the pricing engine (instead of editing the product directly).
  suggestedSalePrice Float     @default(0)
  // Cumulative quantity returned to the supplier via PurchaseReturn records.
  // returnableQty = quantity − returnedQty.
  returnedQty     Int          @default(0)

  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  product         Product       @relation(fields: [productId], references: [id])

  @@index([purchaseOrderId])
  @@index([productId])
}

// ─── MODULE 10: Purchase Returns (مرتجعات المشتريات) ────────────────
// Records goods returned to a supplier against a RECEIVED purchase order.
// Each return decrements inventory, bumps PurchaseOrderItem.returnedQty,
// and generates a reversing journal entry (debit 2010 AP / credit 1010
// Inventory).
model PurchaseReturn {
  id              String   @id @default(cuid())
  returnNo        String   @unique
  purchaseOrderId String
  supplierId      String
  total           Float    @default(0)
  note            String?
  status          String   @default("APPROVED") // APPROVED | CANCELLED
  createdById     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  purchaseOrder   PurchaseOrder       @relation(fields: [purchaseOrderId], references: [id])
  supplier        Supplier            @relation(fields: [supplierId], references: [id])
  createdBy       User?               @relation(fields: [createdById], references: [id], onDelete: SetNull)
  items           PurchaseReturnItem[]

  @@index([purchaseOrderId])
  @@index([supplierId])
  @@index([createdAt])
}

model PurchaseReturnItem {
  id                String   @id @default(cuid())
  purchaseReturnId  String
  productId         String
  quantity          Int
  unitCost          Float
  subtotal          Float

  purchaseReturn    PurchaseReturn @relation(fields: [purchaseReturnId], references: [id], onDelete: Cascade)
  product           Product        @relation(fields: [productId], references: [id])

  @@index([purchaseReturnId])
  @@index([productId])
}

model Sale {
  id           String     @id @default(cuid())
  invoiceNo    String     @unique
  customerName String?
  customerPhone String?
  customerId   String?
  subtotal     Float      @default(0)
  taxRate      Float      @default(15)
  taxAmount    Float      @default(0)
  discount     Float      @default(0)
  total        Float      @default(0)
  paid         Float      @default(0)
  refundTotal  Float      @default(0) // cumulative refunded amount
  refundStatus String     @default("NONE") // NONE | PARTIAL | FULL
  paymentMethod String    @default("CASH") // CASH | CARD | TRANSFER
  deliveryFee  Float      @default(0) // delivery fee (0 = no delivery)
  driverName   String?    // optional delivery driver name
  userId       String?
  createdAt    DateTime   @default(now())

  user         User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  customer     Customer?  @relation(fields: [customerId], references: [id], onDelete: SetNull)
  items        SaleItem[]

  @@index([createdAt])
  @@index([userId])
  @@index([customerId])
  @@index([paymentMethod])
}

model SaleItem {
  id          String @id @default(cuid())
  saleId      String
  productId   String
  quantity    Int
  returnedQty Int    @default(0) // how many units have been returned
  unitPrice   Float
  subtotal    Float

  sale      Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id])

  @@index([saleId])
  @@index([productId])
}

// ─── MODULE 1: Accounting ───────────────────────────────────────────
// Chart of Accounts: hierarchical tree (Assets, Liabilities, Equity, Revenues, Expenses)
model Account {
  id        String    @id @default(cuid())
  code      String    @unique // e.g. "1000", "1001"
  name      String
  type      String    // ASSET | LIABILITY | EQUITY | REVENUE | EXPENSE
  parentId  String?
  balance   Float     @default(0) // signed balance in KWD
  isSystem  Boolean   @default(false) // system accounts cannot be deleted
  createdAt DateTime  @default(now())

  parent    Account?  @relation("AccountTree", fields: [parentId], references: [id], onDelete: SetNull)
  children  Account[] @relation("AccountTree")
  expenses  ExpenseTransaction[]
  journalLines JournalLine[]

  @@index([parentId])
  @@index([type])
}

// Salaries & Administrative expenses ledger entries
model ExpenseTransaction {
  id               String   @id @default(cuid())
  type             String   // SALARY | ADMIN
  // SALARY fields
  employeeName     String?
  payDate          DateTime?
  // ADMIN fields
  title            String?
  category         String?  // Rent | Utilities | Subscriptions | Marketing | Other
  date             DateTime?
  // shared
  amount           Float
  accountId        String   // the expense account this posts to
  paymentAccountId String   // the asset account (Cash/Bank) credited
  note             String?
  createdAt        DateTime @default(now())

  account          Account  @relation(fields: [accountId], references: [id])

  @@index([accountId])
  @@index([type])
  @@index([date])
}

// ─── MODULE 2: Minimal Customer CRM ─────────────────────────────────
model Customer {
  id        String   @id @default(cuid())
  name      String
  phone     String
  address   String
  type      String   @default("RETAIL") // RETAIL | WHOLESALE | CORPORATE
  // Loyalty points system
  loyaltyPoints  Int     @default(0)
  loyaltyTier    String? // BRONZE | SILVER | GOLD (null = no tier)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  sales     Sale[]

  @@index([phone])
}

// ─── Settings (key-value) — active country, currency, tax ───────────
model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

// ─── Double-entry Journal (القيد المحاسبي) ─────────────────────────
model JournalEntry {
  id          String         @id @default(cuid())
  entryNo     String         @unique // e.g. JE-00001
  date        DateTime       @default(now())
  sourceType  String         // SALE | EXPENSE | PURCHASE | MANUAL
  sourceId    String?
  description String
  totalDebit  Float          @default(0)
  totalCredit Float          @default(0)
  createdAt   DateTime       @default(now())

  lines       JournalLine[]
  purchaseInvoices PurchaseInvoice[]
  supplierPayments SupplierPayment[]

  @@index([sourceType])
  @@index([date])
}

model JournalLine {
  id             String       @id @default(cuid())
  journalEntryId String
  accountId      String
  debit          Float        @default(0)
  credit         Float        @default(0)
  description    String?

  journalEntry   JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  account        Account      @relation(fields: [accountId], references: [id])

  @@index([journalEntryId])
  @@index([accountId])
}

// ─── MODULE 3: Shift Closing & Cash/Terminal Reconciliation ─────────
model Shift {
  id            String   @id @default(cuid())
  shiftNo       String   @unique
  userId        String?
  openedAt      DateTime @default(now())
  closedAt      DateTime?
  status        String   @default("OPEN") // OPEN | CLOSED

  // Opening cash balance entered by cashier at shift start
  openingBalance   Float @default(0)

  // System-recorded totals during the shift (from sales by THIS user)
  expectedCash     Float @default(0)
  expectedKnet     Float @default(0) // K-Net card sales
  expectedVisa     Float @default(0) // Visa/Mastercard sales

  // Actual counted amounts at close (entered by supervisor)
  countedCash      Float @default(0)
  countedKnet      Float @default(0) // actual from K-Net terminal receipts
  countedVisa      Float @default(0) // actual from Visa terminal receipts

  // Computed variances (counted − (openingBalance + expected))
  cashVariance     Float @default(0)
  knetVariance     Float @default(0)
  visaVariance     Float @default(0)

  note         String?
  createdAt    DateTime @default(now())

  user         User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([status])
  @@index([openedAt])
}

// ─── MODULE 4: Blind Spot-Check Inventory ───────────────────────────
// Quick surprise count of a single product/category by a supervisor,
// without revealing the book quantity. Variance is computed instantly.
model SpotCheck {
  id           String   @id @default(cuid())
  productId    String
  userId       String?
  // The book (system) quantity at the moment of the check — recorded
  // AFTER the supervisor enters the counted qty to keep the check blind.
  bookQty      Int      @default(0)
  countedQty   Int      @default(0)
  variance     Int      @default(0) // counted − book
  note         String?
  createdAt    DateTime @default(now())

  product      Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user         User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([productId])
  @@index([userId])
  @@index([createdAt])
}

// ─── MODULE 11: Stock Take (جرد المخزون) ────────────────────────────
// A stock take records a physical count of selected products. Created as
// DRAFT (no inventory changes). On APPROVE, product quantities are
// adjusted by `variance` and balanced journal entries are generated:
//   - Shortage (variance < 0): debit 5070 (Stock Shortage) / credit 1010
//   - Surplus  (variance > 0): debit 1010 (Inventory) / credit 4060
model StockTake {
  id           String    @id @default(cuid())
  takeNo       String    @unique
  warehouseId  String?
  note         String?
  status       String    @default("DRAFT") // DRAFT | APPROVED
  createdById  String?
  approvedById String?
  approvedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  warehouse    Warehouse?      @relation(fields: [warehouseId], references: [id], onDelete: SetNull)
  createdBy    User?           @relation("StockTakeCreator", fields: [createdById], references: [id], onDelete: SetNull)
  approvedBy   User?           @relation("StockTakeApprover", fields: [approvedById], references: [id], onDelete: SetNull)
  items        StockTakeItem[]

  @@index([warehouseId])
  @@index([status])
  @@index([createdAt])
}

model StockTakeItem {
  id            String   @id @default(cuid())
  stockTakeId   String
  productId     String
  systemQty     Int      @default(0) // book quantity at creation time
  actualQty     Int      @default(0) // counted physical quantity
  variance      Int      @default(0) // actual − system
  unitCost      Float    @default(0)
  varianceValue Float    @default(0) // variance × unitCost

  stockTake     StockTake @relation(fields: [stockTakeId], references: [id], onDelete: Cascade)
  product       Product   @relation(fields: [productId], references: [id])

  @@index([stockTakeId])
  @@index([productId])
}

// ─── MODULE 12: Stock Transfers (التحويلات بين المخازن) ─────────────
// Transfer goods from one warehouse to another. Created as OUT (in transit,
// quantities already deducted from source). On RECEIVE, quantities are
// added to the destination warehouse.
model StockTransfer {
  id              String    @id @default(cuid())
  transferNo      String    @unique
  fromWarehouseId String
  toWarehouseId   String
  status          String    @default("OUT") // OUT | RECEIVED | CANCELLED
  total           Float     @default(0)
  note            String?
  createdById     String?
  receivedById    String?
  receivedAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  fromWarehouse   Warehouse @relation("FromWarehouse", fields: [fromWarehouseId], references: [id])
  toWarehouse     Warehouse @relation("ToWarehouse", fields: [toWarehouseId], references: [id])
  createdBy       User?     @relation("TransferCreator", fields: [createdById], references: [id], onDelete: SetNull)
  receivedBy      User?     @relation("TransferReceiver", fields: [receivedById], references: [id], onDelete: SetNull)
  items           StockTransferItem[]

  @@index([fromWarehouseId])
  @@index([toWarehouseId])
  @@index([status])
  @@index([createdAt])
}

model StockTransferItem {
  id              String   @id @default(cuid())
  stockTransferId String
  productId       String
  quantity        Int
  unitCost        Float
  subtotal        Float

  stockTransfer   StockTransfer @relation(fields: [stockTransferId], references: [id], onDelete: Cascade)
  product         Product       @relation(fields: [productId], references: [id])

  @@index([stockTransferId])
  @@index([productId])
}

// ─── MODULE 5: Suspended / Parked Sales ─────────────────────────────
// A parked sale holds the cart snapshot (items + customer + totals) so
// the cashier can serve the next customer and resume later.
model SuspendedSale {
  id            String   @id @default(cuid())
  holdNo        String   @unique // e.g. "HOLD-001"
  label         String?  // optional customer name or note
  cartJson      String   // JSON snapshot of cart items + customer + totals
  itemCount     Int      @default(0)
  total         Float    @default(0)
  userId        String?
  createdAt     DateTime @default(now())
  resumedAt     DateTime?
  status        String   @default("PARKED") // PARKED | RESUMED | DISCARDED

  user          User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

// ─── MODULE 6: Exchange / Swap Sales ────────────────────────────────
// An exchange records returned items (negative value) + new items (positive)
// in one transaction. Net settlement = sum of all line values.
// If net > 0 → customer pays the difference (cash/card).
// If net < 0 → refund the difference to customer.
// If net = 0 → even swap, no cash movement.
model ExchangeSale {
  id            String   @id @default(cuid())
  exchangeNo    String   @unique // e.g. "EXC-00001"
  originalSaleId String? // the sale being exchanged against (optional)
  customerName  String?
  customerPhone String?
  netAmount     Float    @default(0) // positive = collect, negative = refund
  paymentMethod String   @default("CASH") // how the net difference is settled
  itemCount     Int      @default(0)
  note          String?
  userId        String?
  createdAt     DateTime @default(now())

  user          User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  lines         ExchangeLine[]
}

model ExchangeLine {
  id            String   @id @default(cuid())
  exchangeId    String
  productId     String
  productName   String
  quantity      Int      // negative = returned, positive = new item
  unitPrice     Float
  lineTotal     Float    // quantity × unitPrice (signed)
  isReturn      Boolean  @default(false)

  exchange      ExchangeSale @relation(fields: [exchangeId], references: [id], onDelete: Cascade)
  product       Product  @relation(fields: [productId], references: [id])

  @@index([exchangeId])
  @@index([productId])
}

// ─── MODULE 7: Pricing Engine — Promotions + Audit Log ──────────────
// Temporary/promotional pricing with a date window. The POS reads the
// active promotion (if any) and applies it as the effective sale price.
//
// A promotion has a SCOPE that determines which products it applies to:
//   PRODUCT               — a single product (productId required)
//   CATEGORY              — all products in one or more categories (categoryIdsJson)
//   ALL                   — every product
//   ALL_EXCEPT_CATEGORIES — every product EXCEPT those in categoryIdsJson
model Promotion {
  id              String   @id @default(cuid())
  productId       String?  // required when scope = PRODUCT; null otherwise
  scope           String   @default("PRODUCT") // PRODUCT | CATEGORY | ALL | ALL_EXCEPT_CATEGORIES
  categoryIdsJson String?  // JSON array of category IDs (CATEGORY + ALL_EXCEPT_CATEGORIES)
  discountType    String   // PERCENT | AMOUNT
  discountValue   Float    // percentage (0-100) or fixed amount in currency
  startAt         DateTime
  endAt           DateTime
  isActive        Boolean  @default(true)
  note            String?
  createdById     String?
  createdAt       DateTime @default(now())

  product         Product?  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdBy       User?     @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@index([productId])
  @@index([isActive])
  @@index([startAt, endAt])
}

// Immutable audit log of every sale-price change. Once written, a row can
// never be updated or deleted — the API enforces this (no PATCH/DELETE).
model PriceChange {
  id           String   @id @default(cuid())
  productId    String
  priceType    String   // RETAIL | WHOLESALE | CORPORATE
  oldPrice     Float
  newPrice     Float
  changedById  String?
  changedAt    DateTime @default(now())
  note         String?

  product      Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  changedBy    User?    @relation(fields: [changedById], references: [id], onDelete: SetNull)

  @@index([productId])
  @@index([changedAt])
}

// ─── MODULE 8: Purchase Invoices / GRN ──────────────────────────────
// A purchase invoice (فاتورة مشتريات) records the receipt of goods from
// a supplier. It can be linked to a PurchaseOrder (optional) and updates
// stock + creates a journal entry when posted.
model PurchaseInvoice {
  id              String   @id @default(cuid())
  invoiceNo       String   @unique
  purchaseOrderId String?
  supplierId      String
  warehouseId     String?
  invoiceDate     DateTime @default(now())
  status          String   @default("DRAFT") // DRAFT | POSTED | CANCELLED
  subtotal        Float    @default(0)
  taxRate         Float    @default(0)
  taxAmount       Float    @default(0)
  discount        Float    @default(0)
  shipping        Float    @default(0)
  customs         Float    @default(0)
  otherCharges    Float    @default(0)
  total           Float    @default(0)
  note            String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  createdById     String?

  purchaseOrder   PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id], onDelete: SetNull)
  supplier        Supplier       @relation(fields: [supplierId], references: [id])
  warehouse       Warehouse?     @relation(fields: [warehouseId], references: [id], onDelete: SetNull)
  items           PurchaseInvoiceItem[]
  journalEntryId  String?
  journalEntry    JournalEntry?  @relation(fields: [journalEntryId], references: [id], onDelete: SetNull)
  createdBy       User?          @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@index([purchaseOrderId])
  @@index([supplierId])
}

model PurchaseInvoiceItem {
  id                  String   @id @default(cuid())
  purchaseInvoiceId   String
  productId           String
  purchaseOrderItemId String?
  quantity            Int
  receivedQty         Int      @default(0)
  unitCost            Float
  subtotal            Float
  landedCost          Float    @default(0)
  note                String?

  purchaseInvoice     PurchaseInvoice @relation(fields: [purchaseInvoiceId], references: [id], onDelete: Cascade)
  product             Product         @relation(fields: [productId], references: [id])

  @@index([purchaseInvoiceId])
}

// ─── MODULE 13: Audit Log (سجل التدقيق) ─────────────────────────────
// Immutable record of sensitive operations (void item, cancel txn, refund,
// exchange, manual discount, drawer open, manager approval). Used to detect
// cashier fraud via void-rate analysis.
model AuditLog {
  id             String   @id @default(cuid())
  userId         String?
  userName       String?
  action         String   // VOID_ITEM | CANCEL_TXN | REFUND | EXCHANGE | MANUAL_DISCOUNT | DRAWER_OPEN | HOLD_BILL | MANAGER_APPROVAL
  description    String?
  saleId         String?
  productId      String?
  supervisorId   String?
  supervisorName String?
  deviceInfo     String?
  metadata       String?
  createdAt      DateTime @default(now())

  @@index([action])
  @@index([userId])
  @@index([createdAt])
}

// ─────────────────────────── Product Bundles ──────────────────────────
// A Bundle is a sellable group of products (e.g. perfume gift set,
// restaurant meal combo). The bundle has its own sale price (usually
// discounted vs. buying components separately). When a bundle is sold
// via POS, the component quantities are deducted from stock.
model Bundle {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  imageUrl    String?
  salePrice   Float    @default(0) // bundle sale price (customer pays this)
  isActive    Boolean  @default(true)
  startDate   DateTime? // optional seasonal activation (e.g. Ramadan)
  endDate     DateTime?   // optional seasonal end
  category    String?    // optional grouping: "perfumes" | "restaurant" | "gifts"...
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items BundleItem[]

  @@index([isActive])
  @@index([category])
}

model BundleItem {
  id        String @id @default(cuid())
  bundleId  String
  productId String
  quantity  Float  @default(1) // how many units of this product are in the bundle
  createdAt DateTime @default(now())

  bundle  Bundle  @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@unique([bundleId, productId])
  @@index([bundleId])
  @@index([productId])
}

// ─────────────────────────── Compositions (التركيبات) ─────────────────
// A Composition is a perfume/recipe made by mixing raw ingredients in
// specific quantities (e.g. 5g oud oil + 3g incense → "Royal Oud" 8g).
// Unlike a Bundle (separate products sold together), a Composition
// PRODUCES a new product — ingredients are consumed from stock and the
// output is a new inventory item.
//
// Use cases:
//   - Perfume shop: custom blends (دهن عود + بخور + مسك)
//   - Restaurant: recipe prep (0.5kg rice + 0.5 chicken + spices → meal)
//   - Manufacturing: BOM (Bill of Materials) for assembled products
model Composition {
  id              String   @id @default(cuid())
  name            String   @unique             // اسم التركيبة
  description     String?
  imageUrl        String?
  outputProductId String                       // the product this composition produces
  yieldQty        Float    @default(1)         // how many units of output per batch
  yieldUnit       String   @default("قطعة")    // unit of the output (gram, ml, piece...)
  isActive        Boolean  @default(true)
  notes           String?                      // preparation instructions, etc.
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  outputProduct Product                 @relation("CompositionOutput", fields: [outputProductId], references: [id], onDelete: Restrict)
  ingredients   CompositionIngredient[]

  @@index([isActive])
  @@index([outputProductId])
}

model CompositionIngredient {
  id             String @id @default(cuid())
  compositionId  String
  productId      String                       // the raw material consumed
  quantity       Float  @default(0)           // amount consumed per batch (gram, ml, piece...)
  unit           String @default("جرام")      // unit of measure for this ingredient
  notes          String?                      // optional note (e.g. "add slowly")
  createdAt      DateTime @default(now())

  composition Composition @relation(fields: [compositionId], references: [id], onDelete: Cascade)
  product     Product      @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@unique([compositionId, productId])
  @@index([compositionId])
  @@index([productId])
}
