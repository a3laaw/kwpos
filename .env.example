# ─── Database — Supabase PostgreSQL ───────────────────────────────
# IMPORTANT: For Prisma interactive transactions ($transaction) to work,
# the Prisma client MUST use a DIRECT connection (port 5432, no pgbouncer).
# The app code in src/lib/db.ts automatically prefers DIRECT_DATABASE_URL
# over DATABASE_URL when both are set.
#
# Pooled connection (pgbouncer, port 6543) — kept for compatibility but
# NOT used by the Prisma client (pgbouncer transaction mode breaks
# interactive transactions). Set this anyway in case other tools read it.
DATABASE_URL="postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:6543/postgres?pgbouncer=true&connection_limit=1"

# Direct connection (port 5432, NO pgbouncer) — THIS is what the app uses.
# Required for $transaction() to work correctly on Supabase.
DIRECT_DATABASE_URL="postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres"

# ─── NextAuth ─────────────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
# Generate a strong secret: openssl rand -base64 32
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# ─── Audit Log Security ───────────────────────────────────────────
# Internal secret required by the /api/audit-logs POST endpoint.
# If not set, the endpoint returns 500 "audit-not-configured".
# Server-side logAuditEvent() calls bypass this (they write directly
# via Prisma) — this secret only guards the HTTP API route.
# Generate a strong secret: openssl rand -base64 32
AUDIT_INTERNAL_SECRET="your-random-secret-here"

# ─── Optional Integrations ────────────────────────────────────────
SHOPIFY_STORE_DOMAIN=""
SHOPIFY_ACCESS_TOKEN=""
