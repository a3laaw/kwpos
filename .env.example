# ─── Database — Supabase PostgreSQL ───────────────────────────────
# IMPORTANT: The app uses DIRECT_DATABASE_URL (port 5432) at runtime
# for interactive transactions. DATABASE_URL (port 6543, pgbouncer) is
# used only for Prisma migrations and as a fallback.
#
# The code in src/lib/db.ts automatically:
#   1. Prefers DIRECT_DATABASE_URL (port 5432)
#   2. Appends connection_limit=1 to prevent pool exhaustion on Vercel
#   3. Caches PrismaClient in globalThis (one client per function instance)

# Pooled connection (pgbouncer, port 6543) — for Prisma migrations only
DATABASE_URL="postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:6543/postgres?pgbouncer=true"

# Direct connection (port 5432, NO pgbouncer) — for app runtime
# THIS is what the Prisma client uses at runtime.
DIRECT_DATABASE_URL="postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres"

# ─── NextAuth ─────────────────────────────────────────────────────
NEXTAUTH_URL="https://your-app.vercel.app"
# Generate a strong secret: openssl rand -base64 32
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# ─── Audit Log Security ───────────────────────────────────────────
# Internal secret required by the /api/audit-logs POST endpoint.
AUDIT_INTERNAL_SECRET="generate-with-openssl-rand-base64-32"

# ─── Optional: Enable Admin DDL endpoints in production ───────────
# Set to "true" ONLY for emergency schema fixes. DDL should normally
# run via Prisma migrations, not via API endpoints.
# ENABLE_ADMIN_DDL="true"

# ─── Optional Integrations ────────────────────────────────────────
SHOPIFY_STORE_DOMAIN=""
SHOPIFY_ACCESS_TOKEN=""
